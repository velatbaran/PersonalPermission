@model UsedAdministrivePermission

@{
    ViewData["Title"] = "İdari İzin Ekle";
}

<form asp-action="Create">
    <div class="row">
        <div class="col-md-6">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            @*             <input type="hidden" asp-for="UserGuid" />
            <input type="hidden" asp-for="YearofBelong" /> *@
            @*             <div class="form-group">
                <h3 style="color:red">@ViewData["WhichYears"] yılına ait kalan izin saat sayısı : @ViewData["RemainHours"]</h3>
            </div> *@
            <div class="form-group">
                <label asp-for="WhichYears" class="control-label"></label>
                <input asp-for="WhichYears" class="form-control" value="@DateTime.Now.Year" readonly />
                <span asp-validation-for="WhichYears" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StartingDate" class="control-label"></label>
                <input asp-for="StartingDate" class="form-control" type="date" />
                <span asp-validation-for="StartingDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StartingTime" class="control-label"></label>
                <input asp-for="StartingTime" class="form-control" />
                <span asp-validation-for="StartingTime" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ExpirationTime" class="control-label"></label>
                <input asp-for="ExpirationTime" class="form-control" />
                <span asp-validation-for="ExpirationTime" class="text-danger"></span><span style="color:red">Dönüş saati girilmeldir.</span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="TotalTime" class="control-label"></label>
                <input asp-for="TotalTime" class="form-control" />
                <span asp-validation-for="TotalTime" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Address" class="control-label"></label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <textarea asp-for="Description" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <button type="submit" class="btn btn-outline-success" title="Kaydet"><i class="fa-solid fa-floppy-disk"></i> Kaydet</button>
                @* <a href="/AdministrativePermission/Index" class="btn btn-outline-secondary" title="İptal"><i class="fa-solid fa-ban"></i> İptal</a> *@
                <a href="/idariizinlerim" class="btn btn-outline-secondary" title="İptal"><i class="fa-solid fa-ban"></i> İptal</a>
            </div>
        </div>
    </div>
</form>
