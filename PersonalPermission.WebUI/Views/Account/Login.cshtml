@model LoginViewModel

@{
    Layout = "_LayoutAccount";
    ViewData["Title"] = "Giriş";
}

<div class="col-xl-10 col-lg-12 col-md-9">

    <div class="card o-hidden border-0 shadow-lg my-5">
        <div class="card-body p-0">
            <!-- Nested Row within Card Body -->
            <div class="row">
                <div class="col-lg-6">
                    <img src="~/admin/img/dsi24.png" width="550" height="550" />
                </div>
                <div class="col-lg-6">
                    <div class="p-5 text-center">
                        <div class="text-center">
                            <h1 class="h4 text-gray-900 mb-4">Giriş Yapabilirsiniz!</h1>
                        </div>
                        <form class="user" asp-controller="Account" asp-action="Login" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <div class="form-group">
                                <input asp-for="Username" class="form-control form-control-user" id="floatingInput" placeholder="Kullanıcı adı..." id="exampleInputEmail" aria-describedby="emailHelp" />
                                <span asp-validation-for="Username" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <input type="password" asp-for="Password" class="form-control form-control-user" id="floatingInput" placeholder="Şifre..." id="exampleInputEmail" aria-describedby="emailHelp" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                            <input type="hidden" asp-for="ReturnUrl" value="@Context.Request.Query["ReturnUrl"]" />
                            <button type="submit" class="btn btn-primary btn-user btn-block" title="Giriş">
                                Giriş
                            </button>
                            <div class="text-right">
                                @* <a class="small" href="/Account/ForgetPassword">Şifremi Unuttum?</a> *@
                                <a class="small" href="/sifremiunuttum" title="Şifremi Unuttum?">Şifremi Unuttum?</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>